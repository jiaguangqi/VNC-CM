# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=rdp
DB_PASSWORD=rdp123
DB_NAME=remote_desktop
DB_SSLMODE=disable
DATABASE_URL=postgres://rdp:rdp123@postgres:5432/remote_desktop?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production-32byte!
JWT_ACCESS_EXPIRY=15
JWT_REFRESH_EXPIRY=7
JWT_ISSUER=remote-desktop-platform

# Encryption
CREDENTIAL_MASTER_KEY=must-be-32-bytes-for-aes256-gcm!

# Ports
HTTP_PORT=8080
SSH_GATEWAY_PORT=8082
PROTOCOL_GATEWAY_PORT=8083

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api/v1
